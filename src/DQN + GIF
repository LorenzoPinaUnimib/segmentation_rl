class BrainTumorEnv(gymnasium.Env):
    def __init__(self, images, target_boxes):
        super(BrainTumorEnv, self).__init__()

        # Imposta immagini e target_boxes
        self.images = images
        self.target_boxes = target_boxes

        # Imposta immagine attuale alla 0
        self.current_img_idx = 0

        # Definisce il numero di azioni disponibili
        self.action_space = spaces.Discrete(8)

        # Definizione dell'immagine e del box
        self.observation_space = spaces.Dict({
            "image": spaces.Box(low=0, high=1, shape=(224, 224, 2), dtype=np.float32),
            "box": spaces.Box(low=0, high=1, shape=(4,), dtype=np.float32)
        })

        # Imposta il conteggio attuale e il numero massimo di passi per episodio
        self.step_count = 0
        self.max_steps = 500

        # Variabili per il reward shaping
        self.prev_dist = None
        self.prev_iou = None

    def reset(self, seed=None):
        super().reset(seed=seed)

        # Sceglie un'immagine casuale
        self.current_img_idx = random.randint(0, len(self.images) - 1)

        # Definiamo una box iniziale al centro dell'immagine
        box_size = 0.5
        start_x = 0.5 - (box_size / 2)
        start_y = 0.5 - (box_size / 2)
        
        self.agent_box = np.array([start_x, start_y, box_size, box_size], dtype=np.float32)
        
        # Imposta il numero di passi a 0
        self.step_count = 0

        # Resetta i valori precedenti per il reward shaping
        self.prev_dist = None
        self.prev_iou = None

        # Restituisce l'immagine e la box (Modificato: usa _get_obs)
        return self.get_obs(), {}

    def step(self, action):
        # Incrementiamo il numero di passi
        self.step_count += 1

        # Definiamo la dimensione del movimento e della box
        move_size = 0.01
        min_size = 0.01

        # Eseguo l'azione scelta
        if action == 0: self.agent_box[1] -= move_size # Su
        elif action == 1: self.agent_box[1] += move_size # Giù
        elif action == 2: self.agent_box[0] -= move_size # Sinistra
        elif action == 3: self.agent_box[0] += move_size # Destra
        elif action == 4: # Espandi Larghezza
            self.agent_box[0] -= move_size / 2
            self.agent_box[2] += move_size
        elif action == 5: # Riduci Larghezza
            if self.agent_box[2] - move_size >= min_size:
                self.agent_box[0] += move_size / 2
                self.agent_box[2] -= move_size
        elif action == 6: # Espandi Altezza
            self.agent_box[1] -= move_size / 2
            self.agent_box[3] += move_size
        elif action == 7: # Riduci Altezza
            if self.agent_box[3] - move_size >= min_size:
                self.agent_box[1] += move_size / 2
                self.agent_box[3] -= move_size

        # Impedisco che la box esca dai bordi superiori e sinistri
        self.agent_box[0] = max(0, self.agent_box[0])
        self.agent_box[1] = max(0, self.agent_box[1])

        # Impedisco che la box esca dai bordi inferiori e destri
        if self.agent_box[0] + self.agent_box[2] > 1.0:
            self.agent_box[0] = 1.0 - self.agent_box[2]
            
        if self.agent_box[1] + self.agent_box[3] > 1.0:
            self.agent_box[1] = 1.0 - self.agent_box[3]

        # Calcola la ricompensa
        reward = self.calculate_reward()

        # Recupero la box target dell'immagine
        target = self.target_boxes[self.current_img_idx]
        
        # Calcolo IoU attuale per info e terminazione
        current_iou = self.calculate_iou(self.agent_box, target)

        # Calcolo la IoU e termino se il valore è sopra la soglia
        terminated = False

        if current_iou > 0.7:
            terminated = True
            reward += 50

        # Controllo se ho raggiunto il massimo numero di passi
        truncated = False

        if self.step_count >= self.max_steps:
            truncated = True

        # Restituisco l'immagine, la box, la reward totale e le informazioni sulla terminazione (Modificato: usa _get_obs)
        return self.get_obs(), reward, terminated, truncated, {"iou": current_iou}
    
    def get_obs(self):
        # Recupero l'immagine attuale
        img = self.images[self.current_img_idx]
        
        # Creo una maschera di zeri
        mask = np.zeros((224, 224), dtype=np.float32)
        
        # Calcolo le coordinate in pixel della box agente
        x, y, w, h = self.agent_box
        x1, y1 = int(x * 224), int(y * 224)
        x2, y2 = int((x + w) * 224), int((y + h) * 224)
        
        # Riempio di 1 l'area interna alla box
        mask[max(0, y1):min(224, y2), max(0, x1):min(224, x2)] = 1.0
        
        # Unisco l'immagine originale e la maschera in un unico tensore
        combined_img = np.stack([img, mask], axis=-1)
        
        return {
            "image": combined_img, 
            "box": self.agent_box,
            "idx": self.current_img_idx
        }

    def calculate_iou(self, boxA, boxB):
        # Calcolo la Intersection over Union
        xA = max(boxA[0], boxB[0])
        yA = max(boxA[1], boxB[1])
        xB = min(boxA[0] + boxA[2], boxB[0] + boxB[2])
        yB = min(boxA[1] + boxA[3], boxB[1] + boxB[3])

        interArea = max(0, xB - xA) * max(0, yB - yA)
        boxAArea = boxA[2] * boxA[3]
        boxBArea = boxB[2] * boxB[3]

        return interArea / float(boxAArea + boxBArea - interArea + 1e-6)

