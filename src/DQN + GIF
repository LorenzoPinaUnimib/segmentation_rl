def build_dqn_model():
    img_input = tf.keras.layers.Input(shape=(224, 224, 2), name="image")

    # Estrazione delle feature dall'immagine
    x = tf.keras.layers.Conv2D(32, 3, activation='relu')(img_input)
    x = tf.keras.layers.MaxPooling2D()(x)
    x = tf.keras.layers.Conv2D(64, 3, activation='relu')(x)
    x = tf.keras.layers.MaxPooling2D()(x)
    x = tf.keras.layers.Conv2D(128, 3, activation='relu')(x)
    x = tf.keras.layers.Flatten()(x)

    # Prendo in input la box attuale
    box_input = tf.keras.layers.Input(shape=(4,), name="box")
    x2 = tf.keras.layers.Dense(32, activation='relu')(box_input)

    # Concateno l'immagine e la box
    combined = tf.keras.layers.Concatenate()([x, x2])

    # Uso una rete che produce in output 8 valori, uno per ogni azione
    dense = tf.keras.layers.Dense(128, activation='relu')(combined)
    dense = tf.keras.layers.Dense(64, activation='relu')(dense)
    output = tf.keras.layers.Dense(8, activation='linear')(dense)

    model = tf.keras.Model(inputs=[img_input, box_input], outputs=output)
    return model

class DQNAgent:
    def __init__(self, action_size):
        self.action_size = action_size

        # Definisce la dimensione della memoria delle ultime esperienze
        self.memory = deque(maxlen=10000) 

        # Quanto conta il futuro rispetto ad adesso
        self.gamma = 0.95

        # Fattore di esplorazione
        self.epsilon = 1.0

        # Fattore minimo di esplorazione
        self.epsilon_min = 0.01

        # Diminuzione dopo ogni allenamento (viene moltiplicato ogni volta)
        self.epsilon_decay = 0.9995

        # Crea la rete neurale
        self.model = build_dqn_model()
        self.target_model = build_dqn_model()
        self.optimizer = tf.keras.optimizers.Adam(learning_rate=0.0007)
        self.update_target_model()

    def update_target_model(self):
        self.target_model.set_weights(self.model.get_weights())

    def act(self, state, training=True):
        # Sceglie se esplorare o meno
        if training and np.random.rand() <= self.epsilon:
            return random.randrange(self.action_size)
        
        # Scelgo l'azione che ha valore massimo in base al modello
        img = np.expand_dims(state['image'], axis=0)
        box = np.expand_dims(state['box'], axis=0)
        act_values = self.model([img, box], training=False)
        return np.argmax(act_values[0])

    def remember(self, state, action, reward, next_state, done):
        # Salvo un'esperienza
        self.memory.append((state['idx'], state['box'], action, reward, next_state['idx'], next_state['box'], done))

    def replay(self, batch_size, all_images):
        if len(self.memory) < batch_size:
            return
        
        # Estraggo un minibatch
        minibatch = random.sample(self.memory, batch_size)

        # Funzione interna per generare la maschera e unirla all'immagine
        def create_combined_input(idx, box):
            img = all_images[idx]
            mask = np.zeros((224, 224), dtype=np.float32)
            x, y, w, h = box
            x1, y1 = int(x * 224), int(y * 224)
            x2, y2 = int((x + w) * 224), int((y + h) * 224)
            mask[max(0, y1):min(224, y2), max(0, x1):min(224, x2)] = 1.0
            return np.stack([img, mask], axis=-1)

        # Estrapolo i componenti e genero gli input a 2 canali
        states_img = np.array([create_combined_input(m[0], m[1]) for m in minibatch], dtype=np.float32)
        states_box = np.array([m[1] for m in minibatch], dtype=np.float32)
        
        next_states_img = np.array([create_combined_input(m[4], m[5]) for m in minibatch], dtype=np.float32)
        next_states_box = np.array([m[5] for m in minibatch], dtype=np.float32)
        
        # ... (continuazione del metodo replay)
        rewards = np.array([m[3] for m in minibatch], dtype=np.float32)
        actions = np.array([m[2] for m in minibatch])
        dones = np.array([m[6] for m in minibatch])

        with tf.GradientTape() as tape:
            # Calcolo i valori Q attuali e futuri
            targets = self.model([states_img, states_box], training=True)
            next_q_values = self.target_model([next_states_img, next_states_box], training=False)
            
            # Calcolo il target per l'azione scelta
            max_next_q = tf.reduce_max(next_q_values, axis=1)
            updated_q_values = rewards + (1 - dones) * self.gamma * max_next_q
            
            # Aggiorno il valore dell'azione compiuta
            masks = tf.one_hot(actions, self.action_size)
            current_q_actions = tf.reduce_sum(targets * masks, axis=1)
            loss = tf.reduce_mean(tf.square(updated_q_values - current_q_actions))
            
        # Applico i gradienti
        grads = tape.gradient(loss, self.model.trainable_variables)
        self.optimizer.apply_gradients(zip(grads, self.model.trainable_variables))

        # Diminuisco la epsilon
        if self.epsilon > self.epsilon_min:
            self.epsilon *= self.epsilon_decay

    def save(self, folder="checkpoint", episode=0, rewards_history=[], ious_history=[]):
        # Crea la cartella se non esiste
        if not os.path.exists(folder):
            os.makedirs(folder)
        
        # Salvo i pesi del modello e del target model
        self.model.save_weights(os.path.join(folder, "model.weights.h5"))
        self.target_model.save_weights(os.path.join(folder, "target.weights.h5"))
        
        # Salvo l'epsilon, i reward e IoU per riprendere l'esplorazione dallo stesso punto
        with open(os.path.join(folder, "agent_params.json"), "w") as f:
            json.dump({
                "episode" : episode,
                "epsilon": self.epsilon,
                "rewards_history": rewards_history,
                "ious_history": ious_history
            }, f)

    def load(self, folder="checkpoint"):
        # Verifico se i file esistono prima di caricare
        if os.path.exists(os.path.join(folder, "model.weights.h5")):
            self.model.load_weights(os.path.join(folder, "model.weights.h5"))
            self.target_model.load_weights(os.path.join(folder, "target.weights.h5"))
            
            with open(os.path.join(folder, "agent_params.json"), "r") as f:
                params = json.load(f)
                self.epsilon = params.get("epsilon", self.epsilon)
                return True, params.get("episode", 0), params.get("rewards_history", []), params.get("ious_history", [])
            
        return False, 0, [], []

def load_coco_dataset(folder_path):
    # Carico il file delle annotazioni
    ann_file = os.path.join(folder_path, "_annotations.coco.json")
    with open(ann_file, 'r') as f:
        coco_data = json.load(f)

    # Definisco gli array in cui salverò le immagini
    images_list = []
    boxes_list = []

    # Mappo le immagini ai dati nelle annotazioni
    img_map = {img['id']: img['file_name'] for img in coco_data['images']}
    processed_images = set()

    for ann in coco_data['annotations']:
        # Recupero l'id immagine
        img_id = ann['image_id']
        if img_id in processed_images:
            continue

        # Cerco la foto nella cartella
        file_name = img_map.get(img_id)
        if not file_name:
            continue

        # Leggo l'immagine
        img_path = os.path.join(folder_path, file_name)
        image = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)
        if image is None:
            continue

        # Ridimensiono l'immagine
        image = cv2.resize(image, (224, 224))
        image = image.astype(np.float32) / 255.0
        
        # Normalizzo la box
        bbox = ann['bbox'] 
        orig_w, orig_h = 0, 0

        for img_info in coco_data['images']:
            if img_info['id'] == img_id:
                orig_w = img_info['width']
                orig_h = img_info['height']
                break

        norm_bbox = [bbox[0] / orig_w, bbox[1] / orig_h, bbox[2] / orig_w, bbox[3] / orig_h]

        # Aggiungo l'immagine e la box alla lista
        images_list.append(image)
        boxes_list.append(norm_bbox)
        processed_images.add(img_id)
    return np.array(images_list, dtype=np.float32), np.array(boxes_list, dtype=np.float32)

def visualize_progress_gif(env, agent, episode):
    # Definisco il numero di sample da testare
    num_samples = 10

    # Creo la figura
    fig, ax = plt.subplots(figsize=(4, 4))
    
    for i in range(num_samples):
        # Scelgo un'immagine casuale
        if (i <= 5):
            idx = i * 10
        else:
            idx = random.randint(0, len(env.images) - 1)
        
        # Imposto l'immagine nell'ambiente
        state, _ = env.reset()
        env.current_img_idx = idx
        img = env.images[idx]
        target_box = env.target_boxes[idx]
        
        # Array per salvare i frame della GIF
        frames = []

        # Resetto l'asse per ogni nuovo sample
        ax.clear()
        ax.imshow(img, cmap='gray')
        ax.axis('off')

        # Rettangolo reale (fisso per l'immagine)
        rect_real = patches.Rectangle(
            (target_box[0]*224, target_box[1]*224), 
            target_box[2]*224, target_box[3]*224, 
            linewidth=2, edgecolor='r', facecolor='none', label='Reale'
        )
        ax.add_patch(rect_real)
        
        # Rettangolo agente (che si aggiorna ad ogni step)
        rect_agent = patches.Rectangle(
            (0, 0), 0, 0, 
            linewidth=2, edgecolor='g', facecolor='none', label='Agente'
        )
        ax.add_patch(rect_agent)

        # Simulo l'agente
        for step in range(200):
            action = agent.act(state, training=False)
            next_state, reward, terminated, truncated, _ = env.step(action)
            state = next_state
            
            # Genero il frame
            current_box = state['box']
            
            # Aggiorno le coordinate del rettangolo esistente
            rect_agent.set_xy((current_box[0]*224, current_box[1]*224))
            rect_agent.set_width(current_box[2]*224)
            rect_agent.set_height(current_box[3]*224)

            ax.set_title(f"Ep {episode} - Img {i+1} - Step {step} - Reward: {reward:.2f}")
            
            fig.canvas.draw()
            image = np.asarray(fig.canvas.buffer_rgba()).copy()
            image = image[:, :, :3]
            
            # Aggiunto l'immagine ai frame
            frames.append(image)
            
            if terminated or truncated:
                break
        
        # Salvo i frame come GIF
        imageio.mimsave(f"progress_ep{episode}_img{i+1}.gif", frames, fps=10)
    # Chiudo la figura
    plt.close(fig)

def __main__():
    # Caricamento dataset
    dataset_path = kagglehub.dataset_download("pkdarabi/brain-tumor-image-dataset-semantic-segmentation")
    train_images, train_boxes = load_coco_dataset(os.path.join(dataset_path, "train"))
    test_images, test_boxes = load_coco_dataset(os.path.join(dataset_path, "test"))

    # Definizione ambiente e agente
    env_train = BrainTumorEnv(train_images, train_boxes)
    env_test = BrainTumorEnv(test_images, test_boxes)
    agent = DQNAgent(action_size=8)

    # Array per tracciare variazioni
    rewards_history = []
    ious_history = []

    # Controllo la presenza di checkpoint
    start_episode = 0
    loaded, start_episode, rewards_history, ious_history = agent.load("checkpoint")

    if loaded:
        print("Modello caricato correttamente dal checkpoint. Riprendo l'addestramento...")
    else:
        print("Nessun checkpoint trovato. Inizio addestramento da zero.")

    # Definizione variabili di addestramento
    episodes = 4000
    batch_size = 64

    # Ciclo di addestramento
    for e in range(start_episode, episodes):
        # Resetto l'ambiente e le variabili
        state, _ = env_train.reset() 
        total_reward = 0
        episode_ious = []
        
        # Singolo ciclo di addestramento
        for step in range(env_train.max_steps):
            # Determino la prossima azione e la eseguo
            action = agent.act(state)
            next_state, reward, terminated, truncated, info = env_train.step(action)

            # Verifico se ho terminato
            done = terminated or truncated
            
            # Salvo l'IoU di ogni step per l'analisi
            episode_ious.append(info['iou'])
            
            # Aggiungo alla memoria questa azione
            agent.remember(state, action, reward, next_state, done)

            # Aggiorno lo stato e la reward
            state = next_state
            total_reward += reward

            if step % (env_train.max_steps // 5) == 0:
                # Aggiorno la rete neurale
                agent.replay(batch_size, train_images)

            if done:
                break
        
        # Aggiungo IoU e reward alla history
        final_iou = episode_ious[-1] if episode_ious else 0
        rewards_history.append(total_reward)
        ious_history.append(final_iou)
        
        # Stampo dei dati di verifica ogni 20 episodi
        if (e + 1) % 20 == 0:
            agent.update_target_model()
            avg_reward = np.mean(rewards_history[-20:])
            avg_iou = np.mean(ious_history[-20:])
            print(f"Episodio: {e+1}/{episodes}, Reward: {total_reward:.2f}, Media 20 ep: {avg_reward:.2f}, IoU Media 20 ep: {avg_iou:.4f}, Epsilon: {agent.epsilon:.2f}")
        
        # Salvo ogni 100 episodi per riprendere successivamente
        if (e + 1) % 100 == 0:
            agent.save("checkpoint", e + 1, rewards_history, ious_history)
            print(f"Checkpoint salvato all'episodio {e+1}")

        # Eseguo un agente e stampo tutte le mosse nell'immagine per verificare il livello di apprendimento
        if (e + 1) % 200 == 0:
            visualize_progress_gif(env_train, agent, e + 1)

    
    print("\nInizio Fase di Test...")

    # Definisco le variabili usare nella fase di test
    test_episodes = 200
    successes = 0
    test_ious = []

    # Ciclo di test
    for e in range(test_episodes):
        # Reset dell'ambiente
        state, _ = env_test.reset()
        done = False
        final_iou_ep = 0

        while not done:
            # Eseguo un'azione
            action = agent.act(state, training=False)
            next_state, reward, terminated, truncated, info = env_test.step(action)
            state = next_state

            # Tengo traccia della IoU
            final_iou_ep = info['iou']

            # Determino se devo continuare o meno
            done = terminated or truncated
            if terminated:
                successes += 1
                break

        # Aggiunto la IoU alle altre
        test_ious.append(final_iou_ep)

    print(f"Test completato. Success Rate: {(successes/test_episodes)*100:.2f}%")
    print(f"IoU Media nel Test Set: {np.mean(test_ious):.4f}")

    # Grafico dei risultati
    plt.figure(figsize=(10, 5))
    plt.plot(rewards_history, label='Reward per Episodio', color='blue', alpha=0.3)
    if len(rewards_history) >= 10:
        moving_avg = np.convolve(rewards_history, np.ones(10)/10, mode='valid')
        plt.plot(range(9, len(rewards_history)), moving_avg, label='Media Mobile (10 ep)', color='red', linewidth=2)
    plt.title("Andamento della Reward durante l'addestramento")
    plt.xlabel("Episodio")
    plt.ylabel("Reward Totale")
    plt.legend()
    plt.grid(True)
    plt.savefig("reward.png")
    plt.show()

if __name__ == "__main__":
    __main__()